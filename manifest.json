{
  "manifest_version": 3,
  "name": "HN Mute",
  "version": "1.0.0",
  "description": "Adds a \"mute\" link next to usernames on Hacker News. Muted users' comments and submissions are hidden",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://news.ycombinator.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "hn-mute@davidoconnor",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
